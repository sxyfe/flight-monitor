{
  "version": 2,
  "env": {
    "BILLING_ENABLED": "false",
    "WEB_ROOT": "/nl-search"
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
